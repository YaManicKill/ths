{
  "name": "rantswithal",
  "version": "1.0.0",
  "description": "Website for Rants With Al",
  "main": "package.json",
  "scripts": {
    "prebuild": "npm run stats:generate",
    "build": "rimraf public/ && hugo",
    "predev": "npm run stats:generate",
    "dev": "rimraf public/ && hugo server --bind 0.0.0.0",
    "postprocess": "node scripts/postprocess/cli.js episode",
    "postprocess:dry": "node scripts/postprocess/cli.js episode --dry-run",
    "top-durations": "node scripts/top-durations.js",
    "host-counts": "node scripts/host-counts.js",
    "stats:generate": "node scripts/generate-episode-stats.js",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yamanickill/rantswithal.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yamanickill/rantswithal/issues"
  },
  "homepage": "https://github.com/yamanickill/rantswithal#readme",
  "dependencies": {
    "hugo-bin": "0.149.2",
    "rimraf": "6.1.2"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
